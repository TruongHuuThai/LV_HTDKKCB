  TBR_LAST_SENT_AT  DateTime? @db.Timestamp(6)
  TBR_CREATED_AT    DateTime @default(now()) @db.Timestamp(6)
  TBR_UPDATED_AT    DateTime @default(now()) @db.Timestamp(6)
