  TBB_DA_XU_LY        Int         @default(0)
  TBB_THANH_CONG      Int         @default(0)
  TBB_THAT_BAI        Int         @default(0)
  TBB_TRANG_THAI      String      @default("QUEUED")
  TBB_BAT_DAU_LUC     DateTime?   @db.Timestamp(6)
  TBB_HOAN_TAT_LUC    DateTime?   @db.Timestamp(6)
  TBB_BATCH_CHA_MA    Int?
