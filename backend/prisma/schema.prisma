generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model AP_KV {
  AK_MA     Int         @id @default(autoincrement())
  XP_MA     Int
  AK_TEN    String
  XA_PHUONG XA_PHUONG   @relation(fields: [XP_MA], references: [XP_MA], onDelete: NoAction, onUpdate: NoAction)
  BENH_NHAN BENH_NHAN[]

  @@index([XP_MA], map: "idx_ak_xp")
}

model AUDIT_LOG {
  AL_ID         BigInt    @id @default(autoincrement())
  AL_TABLE      String
  AL_ACTION     String
  AL_PK         Json?
  AL_OLD        Json?
  AL_NEW        Json?
  AL_CHANGED_BY String?
  AL_CHANGED_AT DateTime? @default(now()) @db.Timestamp(6)

  @@index([AL_TABLE, AL_CHANGED_AT], map: "idx_audit_table_time")
}

model BAC_SI {
  BS_MA            Int         @id @default(autoincrement())
  CK_MA            Int
  TK_SDT           String?     @unique
  BS_EMAIL         String?
  BS_SDT           String?
  BS_HOC_HAM       String?
  BS_NGAY_CAP_NHAT DateTime?   @default(now()) @db.Timestamp(6)
  BS_DA_XOA        Boolean?    @default(false)
  BS_HO_TEN        String
  BS_NGAY_TAO      DateTime?   @default(now()) @db.Timestamp(6)
  BS_ANH           String?
  CHUYEN_KHOA      CHUYEN_KHOA @relation(fields: [CK_MA], references: [CK_MA], onDelete: NoAction, onUpdate: NoAction)
  TAI_KHOAN        TAI_KHOAN?  @relation(fields: [TK_SDT], references: [TK_SDT], onDelete: NoAction, onUpdate: NoAction)
  LICH_BSK         LICH_BSK[]
  LICH_BSK_MAU     LICH_BSK_MAU[]
  YEU_CAU_LICH_BSK YEU_CAU_LICH_BSK[] @relation("YCL_BACSI")
  YEU_CAU_BS_GOI_Y YEU_CAU_LICH_BSK[] @relation("YCL_BACSI_GOI_Y")

  @@index([CK_MA], map: "idx_bs_ck")
}

model BENH {
  B_MA_ICD   String      @id
  B_TEN_BENH String
  B_MO_TA    String?
  CHAN_DOAN  CHAN_DOAN[]
}

model BENH_NHAN {
  BN_MA           Int               @id @default(autoincrement())
  TK_SDT          String?
  AK_MA           Int?
  BN_LA_NAM       Boolean?
  BN_NGAY_SINH    DateTime?         @db.Date
  BN_HO_CHU_LOT   String?
  BN_TEN          String?
  BN_EMAIL        String?
  BN_CCCD         String?
  BN_SO_BHYT      String?
  BN_QUOC_GIA     String?
  BN_DAN_TOC      String?
  BN_SO_DDCN      String?
  BN_MOI          Boolean?          @default(false)
  BN_SDT_DANG_KY  String?
  BN_DIA_CHI      String?
  BN_QUAN_HE_VOI_TK String?
  BN_DA_VO_HIEU   Boolean?          @default(false)
  BN_ANH          String?
  AP_KV           AP_KV?            @relation(fields: [AK_MA], references: [AK_MA], onDelete: NoAction, onUpdate: NoAction)
  TAI_KHOAN       TAI_KHOAN?        @relation(fields: [TK_SDT], references: [TK_SDT], onDelete: NoAction, onUpdate: NoAction)
  CHI_SO_SUC_KHOE CHI_SO_SUC_KHOE[]
  DANG_KY         DANG_KY[]
}

model BIET_DUOC {
  BD_MA        Int     @id @default(autoincrement())
  BD_TEN       String
  BD_CONG_DUNG String?
  BD_HAM_LUONG String?
  BD_LIEU_DUNG String?
  THUOC        THUOC[]
}

model BUOI {
  B_TEN          String      @id
  B_GIO_BAT_DAU  DateTime?   @db.Time(6)
  B_GIO_KET_THUC DateTime?   @db.Time(6)
  KHUNG_GIO      KHUNG_GIO[]
  LICH_BSK       LICH_BSK[]
  LICH_BSK_MAU   LICH_BSK_MAU[]
  YEU_CAU_BUOI_MOI YEU_CAU_LICH_BSK[] @relation("YCL_BUOI_MOI")
}

model CHAN_DOAN {
  PKB_MA          Int
  B_MA_ICD        String
  BENH            BENH            @relation(fields: [B_MA_ICD], references: [B_MA_ICD], onDelete: NoAction, onUpdate: NoAction)
  PHIEU_KHAM_BENH PHIEU_KHAM_BENH @relation(fields: [PKB_MA], references: [PKB_MA], onDelete: NoAction, onUpdate: NoAction)

  @@id([PKB_MA, B_MA_ICD])
}

model CHI_SO_SUC_KHOE {
  CSSK_MA          Int        @id @default(autoincrement())
  BN_MA            Int?
  CSSK_NGAY_DO     DateTime?  @default(now()) @db.Timestamp(6)
  CSSK_CAN_NANG    Decimal?   @db.Decimal(6, 2)
  CSSK_CHIEU_CAO   Decimal?   @db.Decimal(6, 2)
  CSSK_HUYET_AP    String?
  CSSK_NHIP_TIM    Int?
  CSSK_NHIET_DO    Decimal?   @db.Decimal(4, 2)
  CSSK_DUONG_HUYET Decimal?   @db.Decimal(6, 2)
  CSSK_GHI_CHU     String?
  BENH_NHAN        BENH_NHAN? @relation(fields: [BN_MA], references: [BN_MA], onDelete: NoAction, onUpdate: NoAction)

  @@index([BN_MA], map: "idx_cssk_bn")
}

model CHI_TIET_DON_THUOC {
  DT_MA          Int
  T_MA           Int
  CTDT_LIEU_DUNG String?
  CTDT_SO_LUONG  Int
  CTDT_CACH_DUNG String?
  DON_THUOC      DON_THUOC @relation(fields: [DT_MA], references: [DT_MA], onDelete: NoAction, onUpdate: NoAction)
  THUOC          THUOC     @relation(fields: [T_MA], references: [T_MA], onDelete: NoAction, onUpdate: NoAction)

  @@id([DT_MA, T_MA])
}

model CHUYEN_KHOA {
  CK_MA             Int              @id @default(autoincrement())
  CK_TEN            String
  CK_MO_TA          String?
  CK_DOI_TUONG_KHAM String?
  BAC_SI            BAC_SI[]
  LOAI_HINH_KHAM    LOAI_HINH_KHAM[]
  PHONG             PHONG[]
  LICH_BSK_MAU      LICH_BSK_MAU[]
  LICH_BSK_NHAP     LICH_BSK_NHAP[]
}

model DANG_KY {
  DK_MA            Int              @id @default(autoincrement())
  BN_MA            Int
  LHK_MA           Int?
  BS_MA            Int
  N_NGAY           DateTime         @db.Date
  B_TEN            String
  KG_MA            Int
  DK_TRANG_THAI    String?          @default("CHO_KHAM")
  DK_STT           Int?
  DK_LY_DO_HUY     String?
  DK_TRIEU_CHUNG   String?
  DK_GHI_CHU_TIEN_KHAM String?
  DK_CO_BHYT       Boolean?
  DK_LOAI_BHYT     String?
  DK_CO_BHTN       Boolean?
  DK_BHTN_DON_VI   String?
  DK_PT_THANH_TOAN String?
  DK_TIEN_KHAM_CAP_NHAT_LUC DateTime? @db.Timestamp(6)
  DK_TIEN_KHAM_CAP_NHAT_BOI String?
  DK_THOI_GIAN_TAO DateTime?        @default(now()) @db.Timestamp(6)
  BENH_NHAN        BENH_NHAN        @relation(fields: [BN_MA], references: [BN_MA], onDelete: NoAction, onUpdate: NoAction)
  KHUNG_GIO        KHUNG_GIO        @relation(fields: [KG_MA], references: [KG_MA], onDelete: NoAction, onUpdate: NoAction)
  LOAI_HINH_KHAM   LOAI_HINH_KHAM?  @relation(fields: [LHK_MA], references: [LHK_MA], onDelete: NoAction, onUpdate: NoAction)
  LICH_BSK         LICH_BSK         @relation(fields: [BS_MA, N_NGAY, B_TEN], references: [BS_MA, N_NGAY, B_TEN], onDelete: NoAction, onUpdate: NoAction, map: "fk_dk_lichbsk")
  PHIEU_KHAM_BENH  PHIEU_KHAM_BENH?
  PRE_VISIT_ATTACHMENT PRE_VISIT_ATTACHMENT[]
  THANH_TOAN       THANH_TOAN[]

  @@index([BS_MA, N_NGAY, B_TEN, KG_MA], map: "idx_dk_slot")
  @@index([BN_MA], map: "idx_dk_bn")
  @@index([BS_MA, N_NGAY, B_TEN], map: "idx_dk_lich")
}

model DICHVU {
  DVCLS_MA     Int        @id @default(autoincrement())
  DVCLS_TEN    String
  DVCLS_LOAI   String?
  DVCLS_GIA_DV Decimal?   @default(0) @db.Decimal(12, 2)
  THUCHIEN     THUCHIEN[]
}

model DON_THUOC {
  DT_MA              Int                  @id @default(autoincrement())
  PKB_MA             Int?
  DT_NGAY_TAO        DateTime?            @default(now()) @db.Timestamp(6)
  DT_GHI_CHU         String?
  DT_SO_NGAY_SUNG    Int?
  CHI_TIET_DON_THUOC CHI_TIET_DON_THUOC[]
  PHIEU_KHAM_BENH    PHIEU_KHAM_BENH?     @relation(fields: [PKB_MA], references: [PKB_MA], onDelete: NoAction, onUpdate: NoAction)
}

model DON_VI_TINH {
  DVT_MA  Int     @id @default(autoincrement())
  DVT_TEN String
  THUOC   THUOC[]
}

model KET_QUA_CAN_LAM_SAN {
  PCD_MA         Int
  DVCLS_MA       Int
  KQCLS_HINH_ANH String?
  KQCLS_NHAN_XET String?
  KQCLS_CHI_SO   Json?
  THUCHIEN       THUCHIEN @relation(fields: [PCD_MA, DVCLS_MA], references: [PCD_MA, DVCLS_MA], onDelete: NoAction, onUpdate: NoAction, map: "fk_kqcls_th")

  @@id([PCD_MA, DVCLS_MA])
}

model KHUNG_GIO {
  KG_MA       Int       @id @default(autoincrement())
  B_TEN       String
  KG_BAT_DAU  DateTime  @db.Time(6)
  KG_KET_THUC DateTime  @db.Time(6)
  KG_SO_BN_TOI_DA Int?  @db.SmallInt
  DANG_KY     DANG_KY[]
  BUOI        BUOI      @relation(fields: [B_TEN], references: [B_TEN], onDelete: NoAction, onUpdate: NoAction)

  @@index([B_TEN], map: "idx_kg_buoi")
}

model LICH_BSK {
  BS_MA        Int
  P_MA         Int
  N_NGAY       DateTime  @db.Date
  B_TEN        String
  LBM_ID       Int?
  DLT_TUAN_BAT_DAU DateTime? @db.Date
  LBSK_NGUON   String    @default("legacy_registration")
  LBSK_TRANG_THAI String @default("generated")
  LBSK_TAO_LUC DateTime? @default(now()) @db.Timestamp(6)
  LBSK_CAP_NHAT_LUC DateTime? @default(now()) @db.Timestamp(6)
  LBSK_XAC_NHAN_LUC DateTime? @db.Timestamp(6)
  LBSK_IS_ARCHIVED Boolean @default(false)
  LBSK_ARCHIVED_AT DateTime? @db.Timestamp(6)
  LBSK_ARCHIVED_BY String?
  LBSK_ARCHIVE_REASON String?
  LBSK_TRANGTHAI_DUYET String    @default("pending")
  LBSK_GHI_CHU String?
  LBSK_DUYET_BOI       String?
  LBSK_DUYET_LUC       DateTime? @db.Timestamp(6)
  DANG_KY      DANG_KY[]
  BAC_SI       BAC_SI    @relation(fields: [BS_MA], references: [BS_MA], onDelete: NoAction, onUpdate: NoAction)
  BUOI         BUOI      @relation(fields: [B_TEN], references: [B_TEN], onDelete: NoAction, onUpdate: NoAction)
  NGAY         NGAY      @relation(fields: [N_NGAY], references: [N_NGAY], onDelete: NoAction, onUpdate: NoAction)
  PHONG        PHONG     @relation(fields: [P_MA], references: [P_MA], onDelete: NoAction, onUpdate: NoAction)
  LICH_BSK_MAU LICH_BSK_MAU? @relation(fields: [LBM_ID], references: [LBM_ID], onDelete: SetNull, onUpdate: NoAction)
  DOT_LICH_TUAN DOT_LICH_TUAN? @relation(fields: [DLT_TUAN_BAT_DAU], references: [DLT_TUAN_BAT_DAU], onDelete: SetNull, onUpdate: NoAction)
  YEU_CAU_LICH_BSK YEU_CAU_LICH_BSK[]

  @@id([BS_MA, N_NGAY, B_TEN])
  @@unique([P_MA, N_NGAY, B_TEN], map: "uq_lich_phong_ngay_buoi")
  @@index([LBM_ID], map: "idx_lich_bsk_mau")
  @@index([DLT_TUAN_BAT_DAU], map: "idx_lich_bsk_tuan")
  @@index([LBSK_TRANG_THAI], map: "idx_lich_bsk_trang_thai")
  @@index([LBSK_IS_ARCHIVED], map: "idx_lich_bsk_archived")
}

model LIEU_DUNG_HOAT_CHAT {
  LD_ID             Int     @id @default(autoincrement())
  LD_HOAT_CHAT      String
  LD_DUONG_DUNG     String?
  LD_LIEU_NGUOI_LON String?
  LD_LIEU_TRE_EM    String?
  LD_CHI_DINH       String?
  LD_GHI_CHU        String?
  LD_NGUON          String?

  @@index([LD_HOAT_CHAT], map: "idx_ld_hoatchat")
}

model LOAI_HINH_KHAM {
  LHK_MA      Int         @id @default(autoincrement())
  CK_MA       Int
  LHK_TEN     String
  LHK_GIA     Decimal     @default(0) @db.Decimal(12, 2)
  LHK_MO_TA   String?
  DANG_KY     DANG_KY[]
  CHUYEN_KHOA CHUYEN_KHOA @relation(fields: [CK_MA], references: [CK_MA], onDelete: NoAction, onUpdate: NoAction)

  @@index([CK_MA], map: "idx_lhk_ck")
}

model NGAY {
  N_NGAY        DateTime   @id @db.Date
  N_LA_NGAY_LAM Boolean    @default(true)
  N_GHI_CHU     String?
  LICH_BSK      LICH_BSK[]
}

model NHA_SAN_XUAT {
  NSX_MA            Int     @id @default(autoincrement())
  NSX_TEN           String
  NSX_NUOC_SAN_XUAT String?
  THUOC             THUOC[]
}

model NHOM_THUOC {
  NT_MA  Int     @id @default(autoincrement())
  NT_TEN String
  THUOC  THUOC[]
}

model PHIEU_CDCLS {
  PCD_MA          Int              @id @default(autoincrement())
  PKB_MA          Int?
  PCD_GIO_IN      DateTime?        @default(now()) @db.Timestamp(6)
  PHIEU_KHAM_BENH PHIEU_KHAM_BENH? @relation(fields: [PKB_MA], references: [PKB_MA], onDelete: NoAction, onUpdate: NoAction)
  THUCHIEN        THUCHIEN[]
}

model PHIEU_KHAM_BENH {
  PKB_MA          Int           @id @default(autoincrement())
  DK_MA           Int?          @unique
  PKB_TRIEU_CHUNG String?
  PKB_KET_LUAN    String?
  PKB_LAN_KHAM    Int?
  PKB_LOI_DAN     String?
  CHAN_DOAN       CHAN_DOAN[]
  DON_THUOC       DON_THUOC[]
  PHIEU_CDCLS     PHIEU_CDCLS[]
  DANG_KY         DANG_KY?      @relation(fields: [DK_MA], references: [DK_MA], onDelete: NoAction, onUpdate: NoAction)
  THANH_TOAN      THANH_TOAN[]
}

model PHONG {
  P_MA        Int         @id @default(autoincrement())
  CK_MA       Int
  P_TEN       String
  P_VI_TRI    String?
  LICH_BSK    LICH_BSK[]
  LICH_BSK_MAU LICH_BSK_MAU[]
  YEU_CAU_PHONG_MOI YEU_CAU_LICH_BSK[] @relation("YCL_PHONG_MOI")
  CHUYEN_KHOA CHUYEN_KHOA @relation(fields: [CK_MA], references: [CK_MA], onDelete: NoAction, onUpdate: NoAction)

  @@index([CK_MA], map: "idx_phong_ck")
}

model LICH_BSK_MAU {
  LBM_ID             Int         @id @default(autoincrement())
  BS_MA              Int
  CK_MA              Int
  P_MA               Int
  B_TEN              String
  LBM_THU_TRONG_TUAN Int
  LBM_HIEU_LUC_TU    DateTime    @db.Date
  LBM_HIEU_LUC_DEN   DateTime?   @db.Date
  LBM_TRANG_THAI     String      @default("active")
  LBM_GHI_CHU        String?
  LBM_TAO_LUC        DateTime?   @default(now()) @db.Timestamp(6)
  LBM_TAO_BOI        String?
  LBM_CAP_NHAT_LUC   DateTime?   @default(now()) @db.Timestamp(6)
  LBM_CAP_NHAT_BOI   String?
  BAC_SI             BAC_SI      @relation(fields: [BS_MA], references: [BS_MA], onDelete: NoAction, onUpdate: NoAction)
  CHUYEN_KHOA        CHUYEN_KHOA @relation(fields: [CK_MA], references: [CK_MA], onDelete: NoAction, onUpdate: NoAction)
  PHONG              PHONG       @relation(fields: [P_MA], references: [P_MA], onDelete: NoAction, onUpdate: NoAction)
  BUOI               BUOI        @relation(fields: [B_TEN], references: [B_TEN], onDelete: NoAction, onUpdate: NoAction)
  LICH_BSK           LICH_BSK[]

  @@index([BS_MA], map: "idx_lbm_bs")
  @@index([CK_MA], map: "idx_lbm_ck")
  @@index([P_MA], map: "idx_lbm_phong")
  @@index([LBM_TRANG_THAI, LBM_THU_TRONG_TUAN, B_TEN], map: "idx_lbm_status_slot")
  @@index([BS_MA, LBM_THU_TRONG_TUAN, B_TEN], map: "idx_lbm_bs_slot")
  @@index([P_MA, LBM_THU_TRONG_TUAN, B_TEN], map: "idx_lbm_phong_slot")
  @@index([LBM_HIEU_LUC_TU, LBM_HIEU_LUC_DEN], map: "idx_lbm_hieu_luc")
}

model LICH_BSK_NHAP {
  LBN_ID           Int         @id @default(autoincrement())
  CK_MA            Int
  LBN_TU_NGAY      DateTime    @db.Date
  LBN_DEN_NGAY     DateTime    @db.Date
  LBN_DU_LIEU      Json
  LBN_TAO_LUC      DateTime?   @default(now()) @db.Timestamp(6)
  LBN_TAO_BOI      String?
  LBN_CAP_NHAT_LUC DateTime?   @default(now()) @db.Timestamp(6)
  LBN_CAP_NHAT_BOI String?
  CHUYEN_KHOA      CHUYEN_KHOA @relation(fields: [CK_MA], references: [CK_MA], onDelete: NoAction, onUpdate: NoAction)

  @@index([CK_MA], map: "idx_lbn_ck")
  @@index([LBN_TU_NGAY, LBN_DEN_NGAY], map: "idx_lbn_khoang")
}

model DOT_LICH_TUAN {
  DLT_TUAN_BAT_DAU DateTime  @id @db.Date
  DLT_TUAN_KET_THUC DateTime @db.Date
  DLT_TRANG_THAI   String    @default("generated")
  DLT_SINH_LUC     DateTime? @default(now()) @db.Timestamp(6)
  DLT_SINH_BOI     String?
  DLT_CHOT_LUC     DateTime? @db.Timestamp(6)
  DLT_CHOT_BOI     String?
  DLT_MO_SLOT_LUC  DateTime? @db.Timestamp(6)
  DLT_MO_SLOT_BOI  String?
  DLT_GHI_CHU      String?
  LICH_BSK         LICH_BSK[]

  @@index([DLT_TRANG_THAI], map: "idx_dlt_trang_thai")
}

model YEU_CAU_LICH_BSK {
  YCL_ID                Int        @id @default(autoincrement())
  BS_MA                 Int
  LBSK_N_NGAY           DateTime   @db.Date
  LBSK_B_TEN            String
  YCL_LOAI              String
  YCL_LY_DO             String
  YCL_TRANG_THAI        String     @default("pending")
  YCL_TRANG_THAI_TRUOC  String?
  YCL_NGAY_MOI          DateTime?  @db.Date
  YCL_BUOI_MOI          String?
  YCL_P_MA_MOI          Int?
  YCL_GOI_Y_BS_MA       Int?
  YCL_GHI_CHU_ADMIN     String?
  YCL_TAO_LUC           DateTime?  @default(now()) @db.Timestamp(6)
  YCL_TAO_BOI           String?
  YCL_DUYET_LUC         DateTime?  @db.Timestamp(6)
  YCL_DUYET_BOI         String?
  BAC_SI                BAC_SI     @relation("YCL_BACSI", fields: [BS_MA], references: [BS_MA], onDelete: NoAction, onUpdate: NoAction)
  LICH_BSK              LICH_BSK   @relation(fields: [BS_MA, LBSK_N_NGAY, LBSK_B_TEN], references: [BS_MA, N_NGAY, B_TEN], onDelete: NoAction, onUpdate: NoAction)
  BUOI_MOI_REL          BUOI?      @relation("YCL_BUOI_MOI", fields: [YCL_BUOI_MOI], references: [B_TEN], onDelete: NoAction, onUpdate: NoAction)
  PHONG_MOI             PHONG?     @relation("YCL_PHONG_MOI", fields: [YCL_P_MA_MOI], references: [P_MA], onDelete: NoAction, onUpdate: NoAction)
  BAC_SI_GOI_Y          BAC_SI?    @relation("YCL_BACSI_GOI_Y", fields: [YCL_GOI_Y_BS_MA], references: [BS_MA], onDelete: NoAction, onUpdate: NoAction)

  @@index([BS_MA, YCL_TRANG_THAI], map: "idx_ycl_bs_trang_thai")
  @@index([LBSK_N_NGAY], map: "idx_ycl_ngay")
  @@index([YCL_TAO_LUC], map: "idx_ycl_tao_luc")
}

model TAI_KHOAN {
  TK_SDT           String         @id
  TK_PASS          String
  TK_NGAY_TAO      DateTime?      @default(now()) @db.Timestamp(6)
  TK_NGAY_CAP_NHAT DateTime?      @default(now()) @db.Timestamp(6)
  TK_DA_XOA        Boolean?       @default(false)
  TK_VAI_TRO       String?
  BAC_SI           BAC_SI?
  BENH_NHAN        BENH_NHAN[]
  THONG_BAO        THONG_BAO[]
  XAC_THUC_OTP     XAC_THUC_OTP[]

  REFRESH_TOKEN    REFRESH_TOKEN[]
}

model THANH_TOAN {
  TT_MA             Int              @id @default(autoincrement())
  DK_MA             Int?
  PKB_MA            Int?
  TT_LOAI           String?
  TT_PHUONG_THUC    String?
  TT_PHUONG_THUC_TT String?
  TT_TIEN_KHAM      Decimal?         @default(0) @db.Decimal(12, 2)
  TT_PHI_TIEN_ICH   Decimal?         @default(0) @db.Decimal(12, 2)
  TT_TONG_TIEN      Decimal?         @default(0) @db.Decimal(12, 2)
  TT_TRANG_THAI     String?
  TT_MIEN_GIAM      Decimal?         @default(0) @db.Decimal(12, 2)
  TT_THUC_THU       Decimal?         @default(0) @db.Decimal(12, 2)
  TT_MA_GIAO_DICH   String?
  TT_THOI_GIAN      DateTime?        @default(now()) @db.Timestamp(6)
  DANG_KY           DANG_KY?         @relation(fields: [DK_MA], references: [DK_MA], onDelete: NoAction, onUpdate: NoAction)
  PHIEU_KHAM_BENH   PHIEU_KHAM_BENH? @relation(fields: [PKB_MA], references: [PKB_MA], onDelete: NoAction, onUpdate: NoAction)
}

model THONG_BAO {
  TB_MA         Int        @id @default(autoincrement())
  TK_SDT        String?
  TB_BATCH_MA   Int?
  TB_TIEU_DE    String?
  TB_LOAI       String?
  TB_NOI_DUNG   String?
  TB_TRANG_THAI String?
  TB_THOI_GIAN  DateTime?  @default(now()) @db.Timestamp(6)
  THONG_BAO_BATCH THONG_BAO_BATCH? @relation(fields: [TB_BATCH_MA], references: [TBB_MA], onDelete: SetNull, onUpdate: NoAction)
  TAI_KHOAN     TAI_KHOAN? @relation(fields: [TK_SDT], references: [TK_SDT], onDelete: NoAction, onUpdate: NoAction)

  @@index([TB_BATCH_MA], map: "idx_tb_batch")
  @@index([TK_SDT], map: "idx_tb_tk")
}

model PRE_VISIT_ATTACHMENT {
